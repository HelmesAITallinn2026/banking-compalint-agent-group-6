# Backend API URL — agent reads/writes complaint data via backend
BACKEND_URL=http://localhost:8080

# OpenRouter API key — used for LLM calls (OCR vision model + extraction)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter base URL (don't change this)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OCR model — vision-capable model for image-to-text
OCR_MODEL=z-ai/glm-4.6v

# Extraction model — used for structured data extraction
EXTRACTION_MODEL=z-ai/glm-5.1

# Categorization model
CATEGORIZATION_MODEL=z-ai/glm-5.1

# Data retrieval model
DATA_RETRIEVAL_MODEL=z-ai/glm-5.1

# Drafting model
DRAFTING_MODEL=z-ai/glm-5.1

# Langfuse tracing (optional — leave unset to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL="http://langfuse-web:3000"
LANGFUSE_HOST="http://langfuse-web:3000"
